<p style="color: green"><%= notice %></p>

<% content_for :title, "Desserts" %>

<h1>Desserts</h1>

<div id="desserts">
  <% @desserts.each do |dessert| %>
    <%= render dessert %>
    <p>
      <%= link_to "Show this dessert", dessert %>
    </p>
  <% end %>
</div>

<%= link_to "New dessert", new_dessert_path %>
