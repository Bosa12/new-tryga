<p style="color: green"><%= notice %></p>

<% content_for :title, "Pizzas" %>

<h1>Pizzas</h1>

<%= link_to "Adicionar Pizza", new_pizza_path, class: "btn btn-primary" %>

<div class="container my-2">
  <div class="row">
    <% @pizzas.each do |pizza| %>
      <div class="col-md-4 mb-4">
        <div class="d-flex align-items-stretch">
          <% if pizza.image.attached? %>
            <%= image_tag pizza.image,
                class: "card_order-img-top me-3",
                alt: pizza.name,
                style: "width: 200px; height: 200px; object-fit: cover; border-radius: 8px;" %>
          <% end %>

          <div class="card_order shadow-sm rounded flex-grow-1">
            <div class="card_order-body d-flex flex-column justify-content-between p-3">
              <div class="card-order-info d-flex flex-column justify-content-between">
                <h5 class="card_order-title m-0"><%= pizza.name %></h5>
                <div class="card_order-description mt-2">
                  <p><%= pizza.description %></p>
                  <p><strong>€ <%= pizza.price %></strong></p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    <% end %>
  </div>
</div>
<br>
<p style="color: green"><%= notice %></p>

<% content_for :title, "Bebidas" %>

<h1>Bebidas</h1>

<%= link_to "Adicionar Bebida", new_drink_path, class: "btn btn-primary" %>

<div class="container my-2">
  <div class="row">
    <% @drinks.each do |drink| %>
      <div class="col-md-4 mb-4">
        <div class="d-flex align-items-stretch">
          <% if drink.image.attached? %>
            <%= image_tag drink.image,
                class: "card_order-img-top me-3",
                alt: drink.name,
                style: "width: 200px; height: 200px; object-fit: cover; border-radius: 8px;" %>
          <% end %>

          <div class="card_order shadow-sm rounded flex-grow-1">
            <div class="card_order-body d-flex flex-column justify-content-between p-3">
              <div class="card-order-info d-flex flex-column justify-content-between">
                <h5 class="card_order-title m-0"><%= drink.name %></h5>
                <div class="card_order-description mt-2">
                  <p><%= drink.description %></p>
                  <p><strong>€ <%= drink.price %></strong></p>
                </div>
              </div>
              <div class="mt-3">
                <%= link_to "Editar", edit_drink_path(drink), class: "btn btn-warning btn-sm" %>
                <%= link_to "Remover", drink_path(drink),
                      data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                      class: "btn btn-danger btn-sm" %>
              </div>
            </div>
          </div>

        </div>
      </div>
    <% end %>
  </div>
</div>
