<div class="min-vh-100 bg-dark text-white d-flex flex-column align-items-center">



  <!-- Logo em formato triangular -->
<div class="mb-5 text-center">
  <%= image_tag "tryga.png",
        alt: "Tryga Logo",
        style: "width: 140px; height: auto; clip-path: polygon(50% 0%, 0% 100%, 100% 100%); object-fit: contain; background: white;" %>
</div>

  <!-- Nome da pizzaria no canto direito -->
  <h1 class="fw-bold w-100 text-center p-4">Pizzaria Tryga</h1>

  <!-- Cards lado a lado -->
  <div class="d-flex flex-wrap justify-content-center gap-4">

    <!-- Card 1 -->
    <div class="card text-dark shadow" style="width: 284px; height: 132px;">
      <div class="card-body d-flex flex-column justify-content-center text-center">
        <%= link_to "Tryga Pizzaria Fernão Ferreiro", pizzas_path, class: "fw-semibold text-decoration-none text-dark" %>
        <p class="mt-2 text-secondary">Tel: (+39) 21222-4526</p>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="card text-dark shadow" style="width: 284px; height: 132px;">
      <div class="card-body d-flex flex-column justify-content-center text-center">
        <%= link_to "Tryga Pizzaria Seixal", pizzas_path, class: "fw-semibold text-decoration-none text-dark" %>
        <p class="mt-2 text-secondary">Tel: (+39) 21212-0668</p>
      </div>
    </div>

  </div>
</div>
